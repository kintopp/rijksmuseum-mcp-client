{
  "name": "rijksmuseum-mcp-client",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "description": "Web-based MCP client for the Rijksmuseum MCP+ server — split-pane OpenSeadragon viewer + chat with any tool-use-capable LLM via OpenRouter",
  "scripts": {
    "dev": "concurrently -n client,server -c blue,green \"vite\" \"node --env-file=.env --import tsx src/server/index.ts\"",
    "dev:client": "vite",
    "dev:server": "node --env-file=.env --import tsx src/server/index.ts",
    "build": "vite build && tsc -p tsconfig.node.json",
    "start": "node --env-file=.env dist/index.js"
  },
  "dependencies": {
    "ai": "^4",
    "@ai-sdk/openai-compatible": "^0.2",
    "@ai-sdk/react": "^1",
    "express": "^5",
    "openseadragon": "^6",
    "react": "^19",
    "react-dom": "^19"
  },
  "devDependencies": {
    "@types/express": "^5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4",
    "concurrently": "^9",
    "tsx": "^4",
    "typescript": "^5",
    "vite": "^6"
  }
}
